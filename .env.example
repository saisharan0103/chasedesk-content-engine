OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

TYPEFULLY_API_KEY=your-typefully-api-key-here
# Optional. Leave blank to auto-discover. Inspect with: python -m src.review whoami
TYPEFULLY_SOCIAL_SET_ID=

DRY_RUN=true

POSTS_PER_DAY=3
CHAR_LIMIT=240
TIMEZONE=Asia/Kolkata

POST_WINDOW_START=09:00
POST_WINDOW_END=21:00
MIN_GAP_MINUTES=180

SCHEDULE_RANDOM_SEED=

CANDIDATES_PER_SLOT=4
MAX_REGEN_ATTEMPTS=3
RECENT_POSTS_LOOKBACK=30
SIMILARITY_THRESHOLD=0.6
SEED_COOLDOWN_DAYS=10

HUMAN_REVIEW_COMPETITOR_POSTS=true

CONTENT_DIR=content
LOGS_DIR=logs
